# Echo App — Local Development Environment
# Copy to .env and adjust as needed. docker-compose.yml uses these defaults inline.

API_PORT=8000
ENVIRONMENT=development
LOG_LEVEL=debug

# PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=echoapp
DATABASE_USER=echoapp
DATABASE_PASSWORD=echoapp_dev
DATABASE_SSLMODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# NATS
NATS_URL=nats://localhost:4222

# Storage (MinIO S3-compatible)
STORAGE_BACKEND=s3
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET=echo-media
STORAGE_ACCESS_KEY_ID=minioadmin
STORAGE_SECRET_ACCESS_KEY=minioadmin
STORAGE_FORCE_PATH_STYLE=true

# APNs (iOS push — optional for local dev)
# APNS_KEY_PATH=
# APNS_KEY_ID=
# APNS_TEAM_ID=
# APNS_BUNDLE_ID=com.echo.app
# APNS_ENVIRONMENT=sandbox

# Metagraph
# METAGRAPH_L0_URL=http://localhost:9100
# METAGRAPH_L1_URL=http://localhost:9200

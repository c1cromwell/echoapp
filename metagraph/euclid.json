{
  "github": {
    "organization": "Constellation-Labs",
    "repo": "euclid-development-environment",
    "tag": "v0.19.0"
  },
  "tessellation_version": "4.0.0-rc.0",
  "project_name": "echo-metagraph",
  "framework": {
    "version": "v3.6.0",
    "modules": {
      "l0": "modules/l0",
      "l1": "modules/l1",
      "data_l1": "modules/data_l1"
    }
  },
  "docker": {
    "default_containers": [
      "global-l0",
      "metagraph-l0",
      "currency-l1",
      "data-l1"
    ]
  },
  "layers": {
    "global_l0": {
      "ports": {
        "public": 9000,
        "p2p": 9001,
        "cli": 9002
      }
    },
    "metagraph_l0": {
      "ports": {
        "public": 9200,
        "p2p": 9201,
        "cli": 9202
      }
    },
    "currency_l1": {
      "ports": {
        "public": 9300,
        "p2p": 9301,
        "cli": 9302
      }
    },
    "data_l1": {
      "ports": {
        "public": 9400,
        "p2p": 9401,
        "cli": 9402
      }
    }
  }
}

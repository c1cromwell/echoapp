{
  "name": "echoapp",
  "version": "0.1.0",
  "private": true,
  "description": "Echo - Decentralized Messaging Platform",
  "main": "index.js",
  "scripts": {
    "start": "react-native start",
    "ios": "react-native run-ios",
    "android": "react-native run-android",
    "test": "jest",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json}\"",
    "type-check": "tsc --noEmit",
    "generate-api": "openapi-generator-cli generate -i docs/api/openapi.yaml -g typescript-fetch -o src/api/generated",
    "validate-api": "swagger-cli validate docs/api/openapi.yaml"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-native": "^0.73.0",
    "@react-navigation/native": "^6.1.0",
    "@react-navigation/native-stack": "^6.9.0",
    "@react-navigation/bottom-tabs": "^6.5.0",
    "react-native-screens": "^3.29.0",
    "react-native-safe-area-context": "^4.8.0",
    "react-native-gesture-handler": "^2.14.0",
    "react-native-reanimated": "^3.6.0",
    "zustand": "^4.4.0",
    "react-query": "^3.39.0",
    "@tanstack/react-query": "^5.0.0",
    "axios": "^1.6.0",
    "date-fns": "^3.0.0",
    "lodash": "^4.17.21",
    "uuid": "^9.0.0",
    "react-native-keychain": "^8.1.0",
    "react-native-mmkv": "^2.11.0",
    "@ethersproject/wallet": "^5.7.0",
    "react-native-webrtc": "^118.0.0",
    "react-native-incall-manager": "^4.1.0",
    "nativewind": "^2.0.0",
    "react-native-svg": "^14.1.0",
    "react-native-fast-image": "^8.6.0",
    "react-native-document-picker": "^9.1.0",
    "react-native-fs": "^2.20.0",
    "react-native-image-picker": "^7.1.0",
    "react-native-video": "^5.2.0",
    "@notifee/react-native": "^7.8.0",
    "socket.io-client": "^4.7.0"

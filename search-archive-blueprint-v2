**Rule Definition:**

```typescript
interface ArchiveRule {
  id: string;
  name: string;
  enabled: boolean;
  priority: number;        // Lower = higher priority
  
  // Conditions (AND logic within, OR between condition groups)
  conditions: ConditionGroup[];
  
  // Action
  action: {
    type: 'archive' | 'delete' | 'move';
    targetFolder?: string;
    retentionDays?: number;
  };
  
  // Schedule
  schedule: {
    frequency: 'daily' | 'weekly' | 'monthly';
    time: string;          // HH:MM
    timezone: string;
  };
  
  // Exceptions
  exceptions: {
    pinnedConversations: boolean;  // Never archive if pinned
    innerCircle: boolean;          // Never archive inner circle
    recentActivity: number;        // Days of grace period
  };
}

interface ConditionGroup {
  logic: 'AND' | 'OR';
  conditions: Condition[];
}

type Condition =
  | { type: 'inactivity'; days: number }
  | { type: 'trustLevel'; levels: TrustLevel[]; operator: 'in' | 'notIn' }
  | { type: 'circle'; circles: CircleLevel[]; operator: 'in' | 'notIn' }
  | { type: 'conversationType'; types: ('direct' | 'group')[] }
  | { type: 'messageCount'; count: number; operator: 'lt' | 'gt' | 'eq' }
  | { type: 'mediaCount'; count: number; operator: 'lt' | 'gt' }
  | { type: 'hasLabel'; labels: string[] }
  | { type: 'storageSize'; bytes: number; operator: 'lt' | 'gt' };
```


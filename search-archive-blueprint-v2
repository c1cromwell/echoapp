**Semantic Search Flow:**

```typescript
interface SemanticSearchConfig {
  // Number of candidates from vector search
  vectorCandidates: 100;
  
  // Final results after re-ranking
  finalResults: 20;
  
  // Minimum similarity threshold
  minSimilarity: 0.5;
  
  // Hybrid weighting
  weights: {
    semantic: 0.6;
    keyword: 0.3;
    recency: 0.1;
  };
}

async function semanticSearch(
  query: string,
  config: SemanticSearchConfig
): Promise<SearchResult[]> {
  // 1. Generate query embedding
  const queryEmbedding = await embedModel.encode(query);
  
  // 2. Vector similarity search (ANN)
  const vectorResults = await vectorIndex.search(
    queryEmbedding,
    config.vectorCandidates
  );
  
  // 3. Keyword search for same query
  const keywordResults = await keywordSearch(query);
  
  // 4. Merge and re-rank
  const merged = mergeResults(vectorResults, keywordResults, config.weights);
  
  // 5. Apply trust boosting
  const boosted = applyTrustBoost(merged);
  
  // 6. Return top results
  return boosted.slice(0, config.finalResults);
}
```

**Vector Index Configuration:**

```typescript
interface HNSWConfig {
